# ========================================
# HEALTHVIA BACKEND - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ========================================
# DATABASE (Required)
# ========================================
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/healthvia?retryWrites=true&w=majority

# ========================================
# JWT AUTHENTICATION (Required)
# ========================================
# Generate a secure 256-bit (32 bytes) secret key
# Example: openssl rand -base64 64
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B59703373367639792442264529482B4D6251655468576D5A7134743777217A25432A
jwt.access-token-expiration=900000
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# ZOOM INTEGRATION (Required for video calls)
# ========================================
# Get these from https://marketplace.zoom.us/
# Create a Server-to-Server OAuth app
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_ACCOUNT_ID=your-zoom-account-id
# Optional: Webhook verification secret
ZOOM_WEBHOOK_SECRET=

# ========================================
# CORS CONFIGURATION
# ========================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://healthvia.com,https://www.healthvia.com,https://app.healthvia.com

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=8080

# ========================================
# IYZICO PAYMENT (Required for payments)
# ========================================
# Get these from https://sandbox-merchant.iyzipay.com/
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET_KEY=sandbox-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ========================================
# GOOGLE CLOUD (if using GCP)
# ========================================
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
